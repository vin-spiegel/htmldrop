# Server
PORT=3000
BASE_DOMAIN=localhost
NODE_ENV=development

# Cloudflare R2 (S3-compatible). Leave empty for local filesystem fallback.
CLOUDFLARE_R2_ENDPOINT=
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
CLOUDFLARE_R2_BUCKET_NAME=
CLOUDFLARE_R2_PUBLIC_URL=

# Cloudflare API token (optional; used for DNS/subdomain automation if configured)
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=

# Pin
ANON_TTL_DAYS=7
KEY_TTL_DAYS=30
MAX_HTML_SIZE_BYTES=26214400
RATE_LIMIT_ANON_PER_MINUTE=10
RATE_LIMIT_KEY_PER_MINUTE=60
