# ─────────────────────────────────────────────────────────────
# htmldrop — self-hosting config
# Everything has a sane default; the only value most self-hosters
# need to set is BASE_DOMAIN. Copy to .env and edit.
# ─────────────────────────────────────────────────────────────

# ── Required ──────────────────────────────────────────────────
# Your domain. Artifacts are served at <random>.BASE_DOMAIN, so this
# must be a domain whose wildcard (*.BASE_DOMAIN) points at this server.
# Leave as `localhost` only for local development.
BASE_DOMAIN=localhost

# ── Server (usually provided by your host) ────────────────────
PORT=3000
NODE_ENV=development

# ── Storage (optional) ────────────────────────────────────────
# Leave ALL four blank to use local filesystem storage (./data).
# On ephemeral/container hosts, mount a persistent volume at ./data
# or artifacts are lost on redeploy. Set all four to use S3-compatible
# object storage (Cloudflare R2, AWS S3, MinIO, …) instead.
CLOUDFLARE_R2_ENDPOINT=
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
CLOUDFLARE_R2_BUCKET_NAME=

# ── Tuning (optional — defaults shown) ────────────────────────
ANON_TTL_DAYS=7                  # artifact lifetime without an owner key
KEY_TTL_DAYS=30                  # artifact lifetime with an owner key
MAX_HTML_SIZE_BYTES=26214400     # 25 MiB per artifact
RATE_LIMIT_ANON_PER_MINUTE=10    # publish/view rate limit per IP
RATE_LIMIT_KEY_PER_MINUTE=60     # publish/view rate limit per owner key

# ── SEO (optional) ────────────────────────────────────────────
# Only for the public landing page; irrelevant for private self-hosts.
NAVER_SITE_VERIFICATION=
